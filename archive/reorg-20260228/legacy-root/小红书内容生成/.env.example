# 小红书爬虫配置文件模板
# 复制此文件为 .env 并填写实际值

# ===========================================
# 存储模式
# ===========================================
# 可选值: feishu / local / both
STORAGE_MODE=both

# ===========================================
# 飞书配置
# ===========================================
# 在飞书开放平台创建应用后获取
# https://open.feishu.cn

# 应用凭证
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# 多维表格配置
# app_token: 多维表格 URL 中的字符串，如 https://xxx.feishu.cn/base/xxxx
FEISHU_APP_TOKEN=your_bitable_app_token_here

# table_id: 数据表的 ID
FEISHU_TABLE_ID=your_table_id_here

# ===========================================
# 飞书配置获取步骤
# ===========================================
#
# 1. 创建飞书应用
#    - 访问 https://open.feishu.cn
#    - 创建企业自建应用
#    - 获取 App ID 和 App Secret
#
# 2. 配置应用权限
#    - 添加权限: bitable:app, bitable:record
#    - 发布应用
#
# 3. 创建多维表格
#    - 在飞书中创建多维表格
#    - 从 URL 获取 app_token
#    - 从表格设置获取 table_id
#
# 4. 授权应用访问多维表格
#    - 在多维表格中添加应用为协作者
#
# ===========================================
