# Writer internal API auth
INGEST_SHARED_TOKEN=
INGEST_HMAC_SECRET=

# Runtime switches
INGEST_APPLY_MODE=true
INGEST_NEAR_DUP_THRESHOLD=0.88
INGEST_REPORT_DATE_TZ=Asia/Shanghai

# Auth validation
INGEST_AUTH_MAX_SKEW_SECONDS=600
INGEST_SIGNATURE_REQUIRED=true

# Optional source-kind allowlist (comma-separated). Leave empty to allow all.
INGEST_ALLOWED_SOURCE_KINDS=openclaw-feishu,openclaw-backfill

# Bridge-side runtime (optional in Writer host)
INGEST_WRITER_BASE_URL=http://127.0.0.1:8790
INGEST_TIMEOUT_SEC=20
INGEST_VERIFY_SSL=true
