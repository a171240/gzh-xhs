# Writer internal API auth
INGEST_SHARED_TOKEN=
INGEST_HMAC_SECRET=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
API_KEY=

# Runtime switches
INGEST_APPLY_MODE=true
INGEST_NEAR_DUP_THRESHOLD=0.88
INGEST_REPORT_DATE_TZ=Asia/Shanghai
INGEST_LINK_MIN_CONTENT_CHARS=120
INGEST_LINK_ALLOW_TEST_SKIP=true
INGEST_DOUYIN_STRICT_FULL_TEXT=true
INGEST_DOUYIN_SUMMARY_BLOCK=true
INGEST_DOUYIN_MIN_SENTENCES=3
INGEST_DOUYIN_SOURCE_MODE=hybrid
INGEST_DOUYIN_PIPELINE_MODE=asr_primary
INGEST_DOUYIN_BITABLE_ENABLED=true
INGEST_DOUYIN_BITABLE_READ_FIRST=true
INGEST_DOUYIN_BITABLE_FALLBACK_FULL_SCAN=true
INGEST_DOUYIN_BITABLE_WRITE_BACK=true
INGEST_DOUYIN_ASR_ENABLED=true
# ASR key: supports INGEST_DOUYIN_ASR_API_KEY, also falls back to API_KEY
INGEST_DOUYIN_ASR_API_KEY=
INGEST_DOUYIN_ASR_TIMEOUT_SEC=600
INGEST_DOUYIN_DEDUP_KEY_MODE=video_or_canonical_url
INGEST_DOUYIN_WRITE_SUMMARY=true
INGEST_DOUYIN_WRITE_KEYPOINTS=true

# Optional Bitable integration for Douyin full copy source + writeback
BITABLE_APP_TOKEN=
BITABLE_TABLE_ID=
BITABLE_VIEW_ID=
BITABLE_VIDEO_ID_FIELD=视频ID
BITABLE_LINK_FIELD=视频链接
BITABLE_DESC_FIELD=视频描述
# Douyin 正文读取顺序：先 BITABLE_TEXT_FIELD，再 BITABLE_TEXT_FALLBACK_FIELD
BITABLE_TEXT_FIELD=文案整理
BITABLE_TEXT_FALLBACK_FIELD=文案出参
BITABLE_STATUS_FIELD=入库状态
BITABLE_REASON_FIELD=失败原因

# Auth validation
INGEST_AUTH_MAX_SKEW_SECONDS=600
INGEST_SIGNATURE_REQUIRED=true

# Optional source-kind allowlist (comma-separated). Leave empty to allow all.
INGEST_ALLOWED_SOURCE_KINDS=openclaw-feishu,openclaw-backfill

# Bridge-side runtime (optional in Writer host)
INGEST_WRITER_BASE_URL=http://127.0.0.1:8790
INGEST_TIMEOUT_SEC=20
INGEST_VERIFY_SSL=true

# -----------------------
# WeChat image generation (Evolink)
# -----------------------
EVOLINK_BASE_URL=https://api.evolink.ai
EVOLINK_API_KEY=
EVOLINK_IMAGE_MODEL=nanobanana-2
EVOLINK_IMAGE_SIZE=1080x1440
EVOLINK_IMAGE_QUALITY=high
EVOLINK_IMAGE_NUM=1
EVOLINK_TIMEOUT_SEC=45
EVOLINK_POLL_INTERVAL_SEC=3
EVOLINK_POLL_TIMEOUT_SEC=300
EVOLINK_VERIFY_SSL=true
EVOLINK_NETWORK_RETRY=3
WECHAT_IMAGE_RETRIES=2
SKILL_IMAGE_AUTO_GENERATE=true
SKILL_IMAGE_FAIL_ON_ERROR=false
SKILL_IMAGE_RETRIES=2
SKILL_IMAGE_MODEL=
XHS_PREPARE_AUTO_GENERATE_IMAGES=true
XHS_PREPARE_FORCE_REGENERATE=false
XHS_PREPARE_REQUIRE_IMAGES=true

# -----------------------
# Automation state/scheduler
# -----------------------
# SQLite lock handling
AUTOMATION_DB_TIMEOUT_SEC=30
AUTOMATION_DB_BUSY_TIMEOUT_MS=30000
# Scheduler catch-up window (days)
AUTOMATION_SCHEDULER_MAX_BACKFILL_DAYS=7

# -----------------------
# Metrics collection
# -----------------------
PLAYWRIGHT_PYTHON=python
METRICS_HTTP_TIMEOUT_SEC=20
METRICS_HTTP_VERIFY_SSL=true
METRICS_UI_COLLECT_TIMEOUT_SEC=300
METRICS_UI_COLLECT_STRICT=false

# UI collector commands (stdout must be JSON array)
# Windows cmd: use %METRICS_TARGET_DATE%
WECHAT_METRICS_UI_COLLECT_CMD="%PLAYWRIGHT_PYTHON%" "06-工具/scripts/crawlers/collect_wechat_metrics.py" --date %METRICS_TARGET_DATE%
XHS_METRICS_UI_COLLECT_CMD="%PLAYWRIGHT_PYTHON%" "06-工具/scripts/crawlers/collect_xhs_metrics.py" --date %METRICS_TARGET_DATE%
DOUYIN_METRICS_UI_COLLECT_CMD="%PLAYWRIGHT_PYTHON%" "06-工具/scripts/crawlers/collect_douyin_metrics.py" --date %METRICS_TARGET_DATE%

# Optional official API
WECHAT_METRICS_API_URL=
WECHAT_METRICS_API_BEARER=
XHS_METRICS_API_URL=
XHS_METRICS_API_BEARER=
DOUYIN_METRICS_API_URL=
DOUYIN_METRICS_API_BEARER=

# Optional selector configs and browser profile dirs for UI collectors
WECHAT_METRICS_SELECTOR_FILE=
XHS_METRICS_SELECTOR_FILE=
DOUYIN_METRICS_SELECTOR_FILE=
WECHAT_METRICS_HEADLESS=false
XHS_METRICS_HEADLESS=false
DOUYIN_METRICS_HEADLESS=false
WECHAT_METRICS_LOGIN_TIMEOUT_SEC=120
XHS_METRICS_LOGIN_TIMEOUT_SEC=120
DOUYIN_METRICS_LOGIN_TIMEOUT_SEC=120
WECHAT_PROFILE_DIR=
XHS_PROFILE_DIR=
DOUYIN_PROFILE_DIR=

# Optional: reuse BitBrowser logged-in windows (preferred for stable creator-center scraping)
BITBROWSER_API_BASE=http://127.0.0.1:54345
BITBROWSER_API_KEY=
BITBROWSER_TIMEOUT_SEC=20
BITBROWSER_CDP_TIMEOUT_MS=30000
BITBROWSER_CLOSE_AFTER_COLLECT=false
WECHAT_METRICS_BITBROWSER_PROFILE_ID=
XHS_METRICS_BITBROWSER_PROFILE_ID=
DOUYIN_METRICS_BITBROWSER_PROFILE_ID=
