# BitBrowser global API config.
BITBROWSER_API_BASE=http://127.0.0.1:54345
BITBROWSER_API_KEY=

# XHS account A
XHS_A_BITBROWSER_PROFILE_ID=
XHS_A_SELECTORS_PATH=E:/公众号内容生成/06-工具/scripts/config/selectors.xhs.sample.json

# XHS account B
XHS_B_BITBROWSER_PROFILE_ID=
XHS_B_SELECTORS_PATH=E:/公众号内容生成/06-工具/scripts/config/selectors.xhs.sample.json

# XHS account C
XHS_C_BITBROWSER_PROFILE_ID=
XHS_C_SELECTORS_PATH=E:/公众号内容生成/06-工具/scripts/config/selectors.xhs.sample.json

# Optional tuning
XHS_LOGIN_TIMEOUT_SEC=180
XHS_SLOW_MO_MS=0
BITBROWSER_TIMEOUT_SEC=20
BITBROWSER_CDP_TIMEOUT_MS=30000
